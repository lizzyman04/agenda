---
import Layout from '../layouts/Layout.astro';
---
<Layout title="AGENDA — Uma tarefa espera por você">

  <!-- NAV -->
  <nav class="nav">
    <a href="/" class="nav-brand">
      <img src="/assets/img/agenda-logo.png" alt="AGENDA" />
      <span class="nav-brand-name">AGENDA</span>
    </a>
    <ul class="nav-links">
      <li><a href="#features" data-i18n="nav-features">Funcionalidades</a></li>
      <li><a href="#screenshots" data-i18n="nav-screenshots">Screenshots</a></li>
      <li><a href="/terms/" data-i18n="nav-terms">Termos</a></li>
      <li><a href="/dev/" data-i18n="nav-dev">Desenvolvedores</a></li>
    </ul>
    <div class="nav-right">
      <button id="lang-btn" class="lang-btn" aria-label="Switch language">EN</button>
    </div>
  </nav>

  <!-- HERO -->
  <section class="hero">
    <img src="/assets/img/agenda.png" alt="AGENDA" class="hero-logo" />
    <p class="hero-tagline" data-i18n="hero-tagline">Uma tarefa espera por você!</p>
    <p class="hero-sub" data-i18n="hero-sub">Organize tarefas e finanças em um app mobile privado e offline. Sem internet. Sem servidores. Seus dados, só seus.</p>
    <p class="privacy-badge"><i class="fa-solid fa-lock"></i> <span data-i18n="hero-privacy">100% offline — Seus dados nunca saem do dispositivo</span></p>
    <br />
    <button class="cta-btn" disabled data-i18n="hero-cta">Em breve na Play Store</button>
  </section>

  <!-- FEATURES -->
  <section class="section" id="features">
    <div class="inner">
      <p class="section-label" data-i18n="features-label">Funcionalidades</p>
      <h2 class="section-title" data-i18n="features-title">Tudo em um lugar, só no seu dispositivo</h2>
      <p class="section-sub" data-i18n="features-sub">Produtividade e finanças pessoais com privacidade total.</p>
      <div class="cards-grid">

        <!-- TASK MANAGEMENT -->
        <div class="card">
          <div class="card-icon"><i class="fa-solid fa-clipboard-list"></i></div>
          <h3 data-i18n="feat-tasks-title">Gerenciamento de Tarefas</h3>
          <p data-i18n="feat-tasks-desc">Frameworks de produtividade integrados para organização completa do dia.</p>
          <ul>
            <li data-i18n="feat-tasks-li1">Matriz de Eisenhower (urgente x importante)</li>
            <li data-i18n="feat-tasks-li2">Regra 1-3-5 (1 grande + 3 médias + 5 pequenas)</li>
            <li data-i18n="feat-tasks-li3">GTD — captura, processamento, revisão</li>
            <li data-i18n="feat-tasks-li4">Tarefas recorrentes com reinicialização automática</li>
            <li data-i18n="feat-tasks-li5">Projetos e subtarefas com progresso acumulado</li>
            <li data-i18n="feat-tasks-li6">Busca por palavra-chave e filtros avançados</li>
          </ul>
        </div>

        <!-- FINANCE -->
        <div class="card">
          <div class="card-icon"><i class="fa-solid fa-wallet"></i></div>
          <h3 data-i18n="feat-finance-title">Finanças Pessoais</h3>
          <p data-i18n="feat-finance-desc">Controle completo das suas finanças, armazenado localmente.</p>
          <ul>
            <li data-i18n="feat-finance-li1">Receitas e despesas categorizadas</li>
            <li data-i18n="feat-finance-li2">Orçamentos mensais com alertas</li>
            <li data-i18n="feat-finance-li3">Metas de economia com progresso visual</li>
            <li data-i18n="feat-finance-li4">Dívidas e pagamentos recorrentes</li>
            <li data-i18n="feat-finance-li5">Dashboard com gráficos interativos</li>
            <li data-i18n="feat-finance-li6">Exportação CSV e JSON para backup</li>
          </ul>
        </div>

        <!-- PRIVACY -->
        <div class="card">
          <div class="card-icon"><i class="fa-solid fa-shield-halved"></i></div>
          <h3 data-i18n="feat-privacy-title">Privacidade em Primeiro Lugar</h3>
          <p data-i18n="feat-privacy-desc">Cinco princípios que guiam cada decisão de arquitetura do AGENDA.</p>
          <div class="principles">
            <div class="principle">
              <span class="p-icon"><i class="fa-solid fa-ban"></i></span>
              <h4 data-i18n="priv-p1-title">Zero Dados Externos</h4>
              <p data-i18n="priv-p1-desc">Sem analytics, sem crash reporting</p>
            </div>
            <div class="principle">
              <span class="p-icon"><i class="fa-solid fa-plug-circle-xmark"></i></span>
              <h4 data-i18n="priv-p2-title">100% Offline</h4>
              <p data-i18n="priv-p2-desc">Funciona sem internet em qualquer momento</p>
            </div>
            <div class="principle">
              <span class="p-icon"><i class="fa-solid fa-database"></i></span>
              <h4 data-i18n="priv-p3-title">Armazenamento Local</h4>
              <p data-i18n="priv-p3-desc">Banco de dados exclusivamente no dispositivo</p>
            </div>
            <div class="principle">
              <span class="p-icon"><i class="fa-brands fa-github"></i></span>
              <h4 data-i18n="priv-p4-title">Código Aberto</h4>
              <p data-i18n="priv-p4-desc">Auditável por qualquer pessoa no GitHub</p>
            </div>
            <div class="principle">
              <span class="p-icon"><i class="fa-solid fa-lock"></i></span>
              <h4 data-i18n="priv-p5-title">App Lock</h4>
              <p data-i18n="priv-p5-desc">PIN + biometria para proteger seus dados</p>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- SCREENSHOTS -->
  <section class="section" id="screenshots">
    <div class="inner">
      <p class="section-label" data-i18n="screenshots-label">Visualização</p>
      <h2 class="section-title" data-i18n="screenshots-title">Screenshots</h2>
      <p class="section-sub" data-i18n="screenshots-sub">O app está em desenvolvimento ativo.</p>
      <div class="screenshots-grid">
        <div class="shot-placeholder">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="5" y="2" width="14" height="20" rx="2"/><circle cx="12" cy="17" r=".5" fill="currentColor"/></svg>
          <span data-i18n="screenshot-soon">Em breve</span>
        </div>
        <div class="shot-placeholder">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="5" y="2" width="14" height="20" rx="2"/><circle cx="12" cy="17" r=".5" fill="currentColor"/></svg>
          <span data-i18n="screenshot-soon">Em breve</span>
        </div>
        <div class="shot-placeholder">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="5" y="2" width="14" height="20" rx="2"/><circle cx="12" cy="17" r=".5" fill="currentColor"/></svg>
          <span data-i18n="screenshot-soon">Em breve</span>
        </div>
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="footer">
    <div class="footer-links">
      <a href="/terms/" data-i18n="footer-terms">Termos e Privacidade</a>
      <a href="/dev/" data-i18n="footer-dev">Desenvolvedores</a>
      <a href="https://github.com/lizzyman04/agenda" target="_blank" rel="noopener" data-i18n="footer-github">GitHub</a>
    </div>
    <p class="footer-copy" data-i18n="footer-copy">© 2025 lizzyman04 — AGENDA</p>
  </footer>

</Layout>
